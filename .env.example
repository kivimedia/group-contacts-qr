# Public Supabase URL (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key (SECRET - server-side only). Never expose to the browser.
# Used by the create + read API routes for service-role inserts and reads
# that bypass RLS, since the create flow is anonymous.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public origin where this app is deployed. Used to build the QR target URL.
# Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ---------------------------------------------------------------------------
# OPTIONAL: iPhone CardDAV path (recommended for iOS 26+)
# ---------------------------------------------------------------------------
# iOS 26 broke web-originated multi-vCard import. To restore one-tap "add
# all contacts" on iPhone, point this app at a CardDAV server (Baikal,
# sabre/dav, Radicale, etc.) plus a small admin endpoint that provisions
# per-slug users and signs Apple Configuration Profiles.
#
# If these are LEFT BLANK the app still works - it just shows the Android
# vCard QR as the only path and skips the iPhone card. See README.md
# "iPhone CardDAV setup" for a step-by-step.

# Public CardDAV base URL (your Baikal / sabre install).
# Example: https://carddav.example.com (or https://your-server.example/baikal)
CARDDAV_BASE_URL=

# Admin endpoint base where provision.php + sign.php live.
# Example: https://your-server.example/carddav-admin
CARDDAV_ADMIN_BASE_URL=

# Shared secret. Must match the contents of admin-secret.txt on the server.
CARDDAV_ADMIN_SECRET=

# Bearer secret for the manual /api/group-contacts-qr/<slug>/sync endpoint
# (re-syncs members from Supabase JSONB into the CardDAV addressbook). Pick
# anything random.
CARDDAV_SYNC_SECRET=

# Reverse-DNS prefix used as iOS PayloadIdentifier. Default if unset:
# org.example.gcqr - safe to leave but you SHOULD set it to your own domain
# so iOS doesn't show "org.example..." in Settings.
PROFILE_IDENTIFIER_PREFIX=co.your-domain.gcqr

# Organization name shown in iOS Settings under the installed profile.
PROFILE_ORGANIZATION=Your Org
