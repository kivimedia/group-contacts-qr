# Public Supabase URL (safe to expose).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Service-role key (SECRET — server-side only). Never expose to the browser.
# Used by the create + read API routes for service-role inserts and reads
# that bypass RLS, since the create flow is anonymous.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public origin where this app is deployed. Used to build the QR target URL.
# Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
